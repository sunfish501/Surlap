<?xml version="1.0" encoding="utf-8"?>
<!-- Surlap 위젯 (Now/Next 카드) — RemoteViews 제약 안에서 목업 1:1.
     딥퍼플 그라데이션 배경 + 라벤더 accent + 교시 세그먼트 바. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/surlap_widget_bg"
    android:padding="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="지금"
            android:textColor="#FF8E8C97"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="다음"
            android:textColor="#FF8E8C97"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/widget_now_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="#FFFFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText"
                android:text="수업 없음" />
            <TextView
                android:id="@+id/widget_now_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFA98BFF"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText"
                android:text="—" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end">
            <TextView
                android:id="@+id/widget_next_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="#FFFFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText"
                android:text="—" />
            <TextView
                android:id="@+id/widget_next_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFA98BFF"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText"
                android:text="—" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_period_bar"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:orientation="horizontal"
        android:layout_marginTop="14dp">
        <FrameLayout
            android:id="@+id/widget_seg_0"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:background="@drawable/widget_seg_default">
            <View
                android:id="@+id/widget_seg_0_tick"
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:background="@android:color/white"
                android:visibility="gone" />
        </FrameLayout>
        <FrameLayout
            android:id="@+id/widget_seg_1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:background="@drawable/widget_seg_default">
            <View
                android:id="@+id/widget_seg_1_tick"
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:background="@android:color/white"
                android:visibility="gone" />
        </FrameLayout>
        <FrameLayout
            android:id="@+id/widget_seg_2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:background="@drawable/widget_seg_default">
            <View
                android:id="@+id/widget_seg_2_tick"
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:background="@android:color/white"
                android:visibility="gone" />
        </FrameLayout>
        <FrameLayout
            android:id="@+id/widget_seg_3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:background="@drawable/widget_seg_default">
            <View
                android:id="@+id/widget_seg_3_tick"
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:background="@android:color/white"
                android:visibility="gone" />
        </FrameLayout>
        <FrameLayout
            android:id="@+id/widget_seg_4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:background="@drawable/widget_seg_default">
            <View
                android:id="@+id/widget_seg_4_tick"
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:background="@android:color/white"
                android:visibility="gone" />
        </FrameLayout>
        <FrameLayout
            android:id="@+id/widget_seg_5"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:background="@drawable/widget_seg_default">
            <View
                android:id="@+id/widget_seg_5_tick"
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:background="@android:color/white"
                android:visibility="gone" />
        </FrameLayout>
        <FrameLayout
            android:id="@+id/widget_seg_6"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/widget_seg_default">
            <View
                android:id="@+id/widget_seg_6_tick"
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:background="@android:color/white"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/widget_remaining"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="11dp"
        android:gravity="center"
        android:textColor="#FFA4A2AD"
        android:textSize="13sp"
        android:textStyle="bold"
        tools:ignore="HardcodedText"
        android:text="—" />

</LinearLayout>
